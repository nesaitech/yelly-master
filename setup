#!/bin/bash
set -euo pipefail

# ─── Colors ───
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${BLUE}[INFO]${NC} $1"; }
ok()    { echo -e "${GREEN}[OK]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
err()   { echo -e "${RED}[ERROR]${NC} $1"; }
step()  { echo -e "${CYAN}[STEP]${NC} ${BOLD}$1${NC}"; }

die() {
  err "$1"
  exit 1
}

# ─── Detect project root ───
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

if [[ ! -f "$PROJECT_ROOT/VERSION" ]]; then
  die "Cannot find VERSION file. Are you running from the correct directory?"
fi

VERSION="$(cat "$PROJECT_ROOT/VERSION" | tr -d '[:space:]')"
info "yelly-master v${VERSION} setup"
echo ""

# ─── Check prerequisites ───
step "Checking prerequisites..."

if ! command -v node &>/dev/null; then
  die "node is not installed. Please install Node.js (https://nodejs.org)"
fi
ok "node $(node --version)"

if ! command -v npm &>/dev/null; then
  die "npm is not installed. Please install npm"
fi
ok "npm $(npm --version)"

echo ""

# ─── Install npm dependencies ───
step "Checking npm dependencies..."

if [[ ! -d "$PROJECT_ROOT/node_modules" ]]; then
  info "Installing npm dependencies..."
  (cd "$PROJECT_ROOT" && npm install)
  ok "Dependencies installed"
else
  ok "node_modules already present"
fi

echo ""

# ─── Host definitions ───
# Helper to get host dir (compatible with bash 3.x — no associative arrays)
get_host_dir() {
  case "$1" in
    claude)   echo "$HOME/.claude" ;;
    codex)    echo "$HOME/.codex" ;;
    cursor)   echo "$HOME/.cursor" ;;
    windsurf) echo "$HOME/.windsurf" ;;
    kiro)     echo "$HOME/.kiro" ;;
    *)        echo "" ;;
  esac
}

# Hosts that use settings.json for permissions
SETTINGS_HOSTS=("claude" "codex" "kiro")

# ─── Detect installed hosts ───
step "Detecting installed AI hosts..."

DETECTED_HOSTS=()

for host in claude codex cursor windsurf kiro; do
  host_dir="$(get_host_dir "$host")"
  if [[ "$host" == "claude" ]]; then
    if [[ -f "$host_dir/settings.json" ]]; then
      DETECTED_HOSTS+=("$host")
      ok "Found $host ($host_dir/settings.json)"
    fi
  else
    if [[ -d "$host_dir" ]]; then
      DETECTED_HOSTS+=("$host")
      ok "Found $host ($host_dir/)"
    fi
  fi
done

if [[ ${#DETECTED_HOSTS[@]} -eq 0 ]]; then
  die "No AI hosts detected. Supported: claude, codex, cursor, windsurf, kiro"
fi

echo ""

# ─── Ask user which hosts to install for ───
SELECTED_HOSTS=()

if [[ ${#DETECTED_HOSTS[@]} -eq 1 ]]; then
  SELECTED_HOSTS=("${DETECTED_HOSTS[0]}")
  info "Auto-selected: ${SELECTED_HOSTS[0]} (only detected host)"
else
  echo -e "${BOLD}Detected hosts:${NC}"
  for i in "${!DETECTED_HOSTS[@]}"; do
    echo "  $((i+1)). ${DETECTED_HOSTS[$i]}"
  done
  echo "  a. All detected hosts"
  echo ""

  read -rp "Install for which hosts? [a]: " choice
  choice="${choice:-a}"

  if [[ "$choice" == "a" || "$choice" == "A" ]]; then
    SELECTED_HOSTS=("${DETECTED_HOSTS[@]}")
  else
    # Parse comma-separated numbers
    IFS=',' read -ra nums <<< "$choice"
    for num in "${nums[@]}"; do
      num="$(echo "$num" | tr -d '[:space:]')"
      if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#DETECTED_HOSTS[@]} )); then
        SELECTED_HOSTS+=("${DETECTED_HOSTS[$((num-1))]}")
      else
        warn "Ignoring invalid selection: $num"
      fi
    done
  fi
fi

if [[ ${#SELECTED_HOSTS[@]} -eq 0 ]]; then
  die "No hosts selected."
fi

info "Installing for: ${SELECTED_HOSTS[*]}"
echo ""

# ─── Skill names (mega-skills) ───
SKILLS=("yelly-code" "yelly-ops" "yelly-quality" "yelly-team")

# Directories/files to symlink from project root into host skills/yelly-master/
SYMLINK_DIRS=("skills" "modules" "bin" "lib" "config" "scripts")
SYMLINK_FILES=("VERSION")

# ─── Permission entries to register ───
PERMISSIONS=(
  'Bash(npm test*)'
  'Bash(npx vitest*)'
  'Bash(node*)'
  'Bash(git log*)'
  'Bash(git diff*)'
  'Bash(git status*)'
  'Bash(git blame*)'
  'Bash(cat */config.yaml)'
  'Read(*)'
  'Grep(*)'
  'Glob(*)'
)

# ─── Helper: create symlink (idempotent) ───
ensure_symlink() {
  local src="$1"
  local dst="$2"

  if [[ -L "$dst" ]]; then
    local current_target
    current_target="$(readlink "$dst")"
    if [[ "$current_target" == "$src" ]]; then
      return 0  # Already correct
    fi
    rm "$dst"
  elif [[ -e "$dst" ]]; then
    warn "Removing existing non-symlink: $dst"
    rm -rf "$dst"
  fi

  ln -s "$src" "$dst"
}

# ─── Helper: resolve SKILL.md template for a host ───
generate_skill_md() {
  local skill_name="$1"
  local host="$2"
  local host_dir="$(get_host_dir "$host")"
  local skills_root="$host_dir/skills/yelly-master/skills"
  local modules_root="$host_dir/skills/yelly-master/modules"
  local bin_root="$host_dir/skills/yelly-master/bin"
  local tmpl="$PROJECT_ROOT/skills/$skill_name/SKILL.md.tmpl"

  if [[ ! -f "$tmpl" ]]; then
    warn "Template not found: $tmpl"
    return 1
  fi

  # Build the preamble into a temp file
  local preamble_file
  preamble_file="$(mktemp)"
  cat > "$preamble_file" <<EOPREAMBLE
<!-- yelly-master v${VERSION} | host: ${host} -->
<!-- Generated file — do not edit. Edit SKILL.md.tmpl instead. -->

**Before starting any work:**

1. Run update check:
\`\`\`bash
${bin_root}/yelly-update-check
\`\`\`

2. Detect repo structure:
\`\`\`bash
${bin_root}/yelly-repo-mode
\`\`\`

3. Load user config:
\`\`\`bash
${bin_root}/yelly-config get update.notify
\`\`\`
EOPREAMBLE

  # Use node for reliable multiline placeholder replacement
  node -e "
    const fs = require('fs');
    let content = fs.readFileSync('$tmpl', 'utf8');
    const preamble = fs.readFileSync('$preamble_file', 'utf8');
    content = content.replace(/\{\{PREAMBLE\}\}/g, preamble.trimEnd());
    content = content.replace(/\{\{MODULES_ROOT\}\}/g, '${modules_root}');
    content = content.replace(/\{\{BIN_ROOT\}\}/g, '${bin_root}');
    content = content.replace(/\{\{SKILLS_ROOT\}\}/g, '${skills_root}');
    content = content.replace(/\{\{VERSION\}\}/g, '${VERSION}');
    content = content.replace(/\{\{HOST\}\}/g, '${host}');
    process.stdout.write(content);
  "

  rm -f "$preamble_file"
}

# ─── Helper: merge permissions into settings.json ───
merge_permissions() {
  local settings_file="$1"

  if [[ ! -f "$settings_file" ]]; then
    # Create new settings.json with permissions
    local perms_json="["
    local first=true
    for perm in "${PERMISSIONS[@]}"; do
      if $first; then
        first=false
      else
        perms_json+=","
      fi
      perms_json+="\"$perm\""
    done
    perms_json+="]"

    cat > "$settings_file" <<EOJSON
{
  "permissions": {
    "allow": ${perms_json}
  }
}
EOJSON
    return 0
  fi

  # File exists — merge using node for safe JSON manipulation
  node -e "
    const fs = require('fs');
    const path = '$settings_file';
    const newPerms = $(printf '%s\n' "${PERMISSIONS[@]}" | node -e "
      const lines = require('fs').readFileSync('/dev/stdin','utf8').trim().split('\n');
      console.log(JSON.stringify(lines));
    ");

    let data;
    try {
      data = JSON.parse(fs.readFileSync(path, 'utf8'));
    } catch (e) {
      data = {};
    }

    if (!data.permissions) data.permissions = {};
    if (!Array.isArray(data.permissions.allow)) data.permissions.allow = [];

    const existing = new Set(data.permissions.allow);
    for (const perm of newPerms) {
      if (!existing.has(perm)) {
        data.permissions.allow.push(perm);
      }
    }

    fs.writeFileSync(path, JSON.stringify(data, null, 2) + '\n');
  "
}

# ─── Per-host installation ───
INSTALLED_HOSTS=()

for host in "${SELECTED_HOSTS[@]}"; do
  step "Installing for ${host}..."
  host_dir="$(get_host_dir "$host")"

  # a. Create yelly-master skills dir
  master_skills_dir="$host_dir/skills/yelly-master"
  mkdir -p "$master_skills_dir"

  # b. Symlink key directories
  for dir in "${SYMLINK_DIRS[@]}"; do
    if [[ -d "$PROJECT_ROOT/$dir" ]]; then
      ensure_symlink "$PROJECT_ROOT/$dir" "$master_skills_dir/$dir"
    else
      warn "Source directory not found: $PROJECT_ROOT/$dir"
    fi
  done

  for file in "${SYMLINK_FILES[@]}"; do
    if [[ -f "$PROJECT_ROOT/$file" ]]; then
      ensure_symlink "$PROJECT_ROOT/$file" "$master_skills_dir/$file"
    else
      warn "Source file not found: $PROJECT_ROOT/$file"
    fi
  done

  ok "Symlinks created in $master_skills_dir/"

  # c & d. Generate SKILL.md for each mega-skill and copy to host
  for skill in "${SKILLS[@]}"; do
    skill_dir="$host_dir/skills/$skill"
    mkdir -p "$skill_dir"

    generated="$(generate_skill_md "$skill" "$host")"
    if [[ -n "$generated" ]]; then
      echo "$generated" > "$skill_dir/SKILL.md"
      ok "Generated $skill_dir/SKILL.md"
    fi
  done

  # e. Register permissions (only for hosts that use settings.json)
  for settings_host in "${SETTINGS_HOSTS[@]}"; do
    if [[ "$host" == "$settings_host" ]]; then
      settings_file="$host_dir/settings.json"
      merge_permissions "$settings_file"
      ok "Permissions merged into $settings_file"
      break
    fi
  done

  INSTALLED_HOSTS+=("$host")
  echo ""
done

# ─── Create user config ───
step "Setting up user configuration..."

USER_CONFIG_DIR="$HOME/.yelly-master"
mkdir -p "$USER_CONFIG_DIR"

if [[ ! -f "$USER_CONFIG_DIR/config.yaml" ]]; then
  if [[ -f "$PROJECT_ROOT/config/defaults.yaml" ]]; then
    cp "$PROJECT_ROOT/config/defaults.yaml" "$USER_CONFIG_DIR/config.yaml"
    ok "Created $USER_CONFIG_DIR/config.yaml from defaults"
  else
    warn "No defaults.yaml found — skipping config creation"
  fi
else
  ok "User config already exists: $USER_CONFIG_DIR/config.yaml"
fi

# ─── Create cache/sessions dirs ───
mkdir -p "$USER_CONFIG_DIR/cache"
mkdir -p "$USER_CONFIG_DIR/sessions"
ok "Cache and sessions directories ready"

echo ""

# ─── Run migrations ───
step "Checking migrations..."

MIGRATIONS_DIR="$PROJECT_ROOT/migrations"
if [[ -d "$MIGRATIONS_DIR" ]]; then
  migration_count="$(find "$MIGRATIONS_DIR" -name '*.sh' -type f 2>/dev/null | wc -l | tr -d '[:space:]')"
  if [[ "$migration_count" -gt 0 ]]; then
    info "Found $migration_count migration(s) — skipping (not implemented yet)"
  else
    ok "No migrations to run"
  fi
else
  ok "No migrations directory"
fi

echo ""

# ─── Summary ───
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}${BOLD}  yelly-master v${VERSION} installed successfully!${NC}"
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "  ${BOLD}Hosts:${NC}       ${INSTALLED_HOSTS[*]}"
echo -e "  ${BOLD}Skills:${NC}      ${SKILLS[*]}"
echo -e "  ${BOLD}Config:${NC}      $USER_CONFIG_DIR/config.yaml"
echo -e "  ${BOLD}Cache:${NC}       $USER_CONFIG_DIR/cache/"
echo -e "  ${BOLD}Sessions:${NC}    $USER_CONFIG_DIR/sessions/"
echo ""

for host in "${INSTALLED_HOSTS[@]}"; do
  host_dir="$(get_host_dir "$host")"
  echo -e "  ${BOLD}${host}:${NC}"
  echo -e "    Shared:  $host_dir/skills/yelly-master/"
  for skill in "${SKILLS[@]}"; do
    echo -e "    Skill:   $host_dir/skills/$skill/SKILL.md"
  done
done

echo ""
echo -e "  Run ${CYAN}./setup${NC} again anytime to update."
echo ""
