{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "declaration": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["lib/**/*.ts", "bin/**/*.ts", "scripts/**/*.ts", "migrations/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
